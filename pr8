#include <iostream>
using namespace std;

int main() {
	setlocale(0, "");
	while (true) {
		int language;
		string russ[15] = { "Дом", "Дорога", "Мышь", "Флаг", "Машина", "Заяц", "Долг", "Топор", "Мяч", "Шум", "Ложка", "Вилка", "Яблоко", "Чай", "Голова" };
		string eng[15] = { "House", "Road", "Mouse", "Flag", "Car", "Hare", "Debt", "Axe", "Ball", "Noise", "Spoon", "Fork", "Apple", "Tea", "Head" };
	
		cout << "[1] Русские слова\n[2] Английские слова\n[3] Выйти\n";
		cin >> language;
		switch (language) {
		case 1:
			cout << "Список русских слов\n";
			for (int i = 0; i < 15; i++) {
				cout << "[" << i + 1 << "]" << russ[i] << endl;
			}
			cout << "Выберите номер слова: "; cin >> language;
			cout << "Перевод: " << russ[language - 1] << " -> " << eng[language - 1] << endl;
			break;
		case 2:
			cout << "Список английских слов\n";
			for (int i = 0; i < 15; i++) {
				cout << "[" << i + 1 << "]" << eng[i] << endl;
			}
			cout << "Выберите номер слова: "; cin >> language;
			cout << "Перевод: " << eng[language - 1] << " -> " << russ[language - 1] << endl;
			break;
		case 3:
			return 0;
		}
	}
}
